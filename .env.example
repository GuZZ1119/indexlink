# Local development defaults only. Do not use these credentials in production.
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info,indexlink_server=debug
DATABASE_URL=sqlite://indexlink.db?mode=rwc
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_MAX_CONNECTIONS=10
DATABASE_CONNECT_TIMEOUT_SECONDS=5
# Fixed-monthly automatic decision audit. It creates evidence only and never submits an order.
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
# Optional: enabling this key enables POST /market-sentiment/preview.
# Never commit a real key. Without it, the route returns a safe 503 response.
# DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_TIMEOUT_SECONDS=30
DASHSCOPE_MAX_TOKENS=128
DASHSCOPE_TEMPERATURE=0.0
# Optional: configuring a provider replaces the in-process MockBroker with a
# local Futu/Moomoo OpenD paper-trading session. This server integration only
# accepts loopback OpenD and never enables live trading.
# OPEND_PROVIDER=futu
# OPEND_HOST=127.0.0.1
# OPEND_PORT=11111
# Optional: configure this when OpenD exposes multiple paper accounts.
# OPEND_ACCOUNT_ID=
